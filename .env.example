# ── PocketBase (acceso local desde PC) ───────────────────────
PB_URL=
PB_EMAIL=
PB_PASSWORD=

# ── MinIO (acceso local desde PC) ────────────────────────────
MINIO_URL=
MINIO_ACCESS=
MINIO_SECRET=

# ── Docker service names (para contenedores en elt-network) ──
PB_URL_DOCKER=http://pocketbase:8090
MINIO_URL_DOCKER=minio:9000

# ── Buckets MinIO ─────────────────────────────────────────────
MINIO_BUCKET_RAW=aerotrack-raw
MINIO_BUCKET_DIMS=aerotrack-dims
MINIO_BUCKET_EXPORTS=aerotrack-exports

# ── Seguridad JWT ────────────────────────────────────────────
SECRET_KEY=
ALGORITHM=HS256
TOKEN_EXPIRE_MINUTES=60

# ── Airflow ───────────────────────────────────────────────────
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=

# ── Rutas del CSV por contexto ────────────────────────────────
CSV_PATH_LOCAL=./data/airline_2m.csv
CSV_PATH_DOCKER=/opt/airflow/data/airline_2m.csv

# ── PocketBase colección y carga ─────────────────────────────
PB_COLLECTION=vuelos_raw
BATCH_SIZE=5000

# ── Base de datos de Airflow (Postgres) ───────────────────────
POSTGRES_USER=airflow
POSTGRES_PASSWORD=
FERNET_KEY=

# ── URLs adicionales (opcional) ───────────────────────────────
# AIRFLOW_URL=http://localhost:8080       # URL de Airflow (solo si NO usas Docker)
# MINIO_PUBLIC_URL=localhost:9000         # Para presigned URLs (si MinIO expone otro host)

# ── API Keys para IA (opcionales, se configuran en PocketBase) ──
# GROQ_API_KEY=gsk_xxxxx
# GEMINI_API_KEY=AIzaSy_xxxxx

# ── Gmail SMTP (solo para configure_email.py, setup inicial) ──
# GMAIL_ADDRESS=tu@gmail.com
# GMAIL_APP_PASS=xxxx xxxx xxxx xxxx

# ── Usuario admin inicial (setup) ─────────────────────────────
# ADMIN_NAME="Tu Nombre"
